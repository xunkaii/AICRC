# AICRC_v2 — environment variable template (committed to git).
# Copy this file to .env and fill in real values:
#   PowerShell:  Copy-Item .env.example .env
#   bash:        cp .env.example .env
# Then edit .env to add your real API keys.
#
# .env is gitignored; .env.example is the only env file tracked.

# --- Anthropic (Claude) ----------------------------------------------------
# Used by scripts/generate_step7_v2_captions.py --provider anthropic
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI ----------------------------------------------------------------
# Used by scripts/generate_step7_v2_captions.py --provider openai
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Optional: model overrides --------------------------------------------
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_MODEL=gpt-4o-mini
