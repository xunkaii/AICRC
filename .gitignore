# --- Secrets / env --------------------------------------------------------
# .env contains API keys (ANTHROPIC_API_KEY, OPENAI_API_KEY, ...) and MUST
# never be committed. .env.example is committed to document required vars.
.env
.env.*
.env.local
.env.*.local
*.env
!.env.example
# Other secret formats
secrets/
*.pem
*.key
*_secret*
*_credentials*

# --- Project-specific outputs --------------------------------------------
# Raw / intermediate data should not be committed; the dataset itself lives
# outside this repo at C:\Users\user\data\AICRC_DSQ_Data(Combined_segmented)_v2.
data/
datasets/

# Manifests, features, predictions, captions
manifests/
features/
predictions/
captions/
cache/

# Training runs / checkpoints / logs
runs/
checkpoints/
logs/
wandb/
mlruns/
outputs/
*.pt
*.pth
*.ckpt
*.onnx
*.h5

# Large CSV / parquet artifacts (keep small reports under reports/)
*.parquet
*.feather

# --- Reports --------------------------------------------------------------
# reports/ IS committed (audit deliverables). Ignore only transient files.
reports/_tmp/
reports/*.bak


